<% content_for :title, "New task" %>

<h1 style="text-align: center;">New task</h1>

<div style="display: flex; max-width: 600px; margin: 20px auto; padding: 30px; border-radius: 12px; background: #ffffff; box-shadow: 0 4px 15px rgba(0,0,0,0.08); font-family: system-ui, -apple-system, sans-serif;">
  <%= render "form", task: @task %>
</div>

<br>

<div style="text-align: center;">
  <%= link_to "Back to tasks", tasks_path %>
</div>