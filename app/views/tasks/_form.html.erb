<%= form_with(model: task, html: { style: "max-width: 450px; margin: 20px auto; padding: 30px; border-radius: 12px; background: #ffffff; box-shadow: 0 4px 15px rgba(0,0,0,0.08); font-family: system-ui, -apple-system, sans-serif;" }) do |form| %>
  
  <% if task.errors.any? %>
    <div style="color: #dc3545; background-color: #f8d7da; border: 1px solid #f5c2c7; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
      <h2 style="font-size: 16px; margin: 0 0 10px 0;"><%= pluralize(task.errors.count, "error") %> prohibited this task from being saved:</h2>
      <ul style="margin: 0; padding-left: 20px; font-size: 14px;">
        <% task.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Title Input Group -->
  <div style="margin-bottom: 20px;">
    <%= form.label :title, "Task Title", style: "display: block; margin-bottom: 8px; font-weight: 600; color: #333; font-size: 14px;" %>
    <%= form.text_field :title, placeholder: "What needs to be done?", style: "width: 100%; padding: 10px 14px; border: 1px solid #cccccc; border-radius: 8px; font-size: 15px; box-sizing: border-box; transition: border-color 0.2s;" %>
  </div>

  <!-- Due Date Input Group -->
  <div style="margin-bottom: 25px;">
    <%= form.label :due_date, "Due Date", style: "display: block; margin-bottom: 8px; font-weight: 600; color: #333; font-size: 14px;" %>
    <%= form.date_field :due_date, style: "width: 100%; padding: 10px 14px; border: 1px solid #cccccc; border-radius: 8px; font-size: 15px; box-sizing: border-box; color: #333;" %>
  </div>

  <!-- Completed Checkbox Group -->
  <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 25px; padding: 10px 0;">
    <%= form.checkbox :completed, style: "width: 18px; height: 18px; cursor: pointer; accent-color: #0d6efd;" %>
    <%= form.label :completed, "Mark as Completed", style: "font-weight: 500; color: #444; font-size: 15px; cursor: pointer;" %>
  </div>

  <!-- Submit Button -->
  <div>
    <%= form.submit style: "width: 100%; background-color: #0d6efd; color: white; padding: 12px; border: none; border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer; transition: background-color 0.2s; box-shadow: 0 2px 4px rgba(13, 110, 253, 0.2);" %>
  </div>

<% end %>